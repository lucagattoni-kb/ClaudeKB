# Controlled vocabulary for this KB (KB-owned). `kbtool check` validates every
# page's `type` and `tags` against these lists. Add terms as the KB grows;
# keeping the lists curated is what stops tag/type sprawl.
types:
  - article      # long-form structured knowledge (the default)
  - reference    # lookup material (tables, specs, glossaries)
  - concept      # a single idea/entity page
  - playbook     # a procedure to execute
tags:
  - {{ kb_name }}
